{
  "name": "myflowforge",
  "version": "1.0.14",
  "description": "A desktop cockpit that orchestrates Claude Code, Codex, Cursor, Gemini and qoder into one governed, multi-stage AI coding workflow.",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "dist": "electron-vite build && electron-builder --mac --x64",
    "dist:dir": "electron-vite build && electron-builder --mac dir --x64",
    "dist:x64": "electron-vite build && electron-builder --mac --x64",
    "dist:arm64": "electron-vite build && electron-builder --mac --arm64",
    "dist:universal": "electron-vite build && electron-builder --mac --universal",
    "dist:mac-all": "bash scripts/build-mac-all.sh",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "postinstall": "chmod +x node_modules/node-pty/prebuilds/darwin-*/spawn-helper 2>/dev/null || true"
  },
  "keywords": [
    "ai",
    "coding-agent",
    "workflow",
    "orchestration",
    "electron",
    "claude-code",
    "codex",
    "cursor",
    "gemini",
    "mcp",
    "developer-tools"
  ],
  "author": "zghua",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xzghua/myFlowForge.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "chokidar": "^5.0.0",
    "electron-vite": "^5.0.0",
    "execa": "^9.6.1",
    "node-pty": "^1.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "undici": "^7.27.2",
    "vite": "^7.3.5",
    "zod": "^4.4.3"
  },
  "comment:overrides": "Force node-gyp 10.x — electron-builder→@electron/rebuild pulls node-gyp 9.x, which fails on Python 3.12+ (distutils removed). 10.x supports Python 3.12/3.13 so `npm run dist` rebuilds node-pty on any machine's Python.",
  "overrides": {
    "node-gyp": "^10.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "electron": "^42.4.0",
    "electron-builder": "^25.1.8",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
